---
import siteConfig from '../data/site.json';
import socialConfig from '../data/social.json';
import footerConfig from '../data/footer.json';

const currentYear = new Date().getFullYear();
const footerText = (footerConfig.copyright || '{year}').replace('{year}', currentYear.toString());

const navLinks = [
  { href: '/', label: 'Accueil' },
  { href: '/parcours', label: 'Parcours' },
  { href: '/projets', label: 'Projets' },
  { href: '/engagement-associatif', label: 'Engagement' },
  { href: '/blog', label: 'Blog' },
  { href: '/sitemap.xml', label: 'Plan du site' },
];
---

<footer class="site-footer">
  <div class="container site-footer__inner">
    <div class="site-footer__top">
      <div class="site-footer__brand">
        <a href="/" class="footer-brand">
          <svg width="24" height="24" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <rect width="32" height="32" rx="8" fill="currentColor" fill-opacity="0.1"/>
            <path d="M8 12h16M8 16h12M8 20h8" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
          </svg>
          <span>{siteConfig.title}</span>
        </a>
      </div>

      <nav class="site-footer__nav" aria-label="Navigation footer">
        {navLinks.map((link) => (
          <a href={link.href}>{link.label}</a>
        ))}
      </nav>

      <div class="site-footer__social" aria-label="Réseaux sociaux">
        {socialConfig.linkedin && (
          <a href={socialConfig.linkedin} target="_blank" rel="noopener noreferrer" class="social-link" aria-label="LinkedIn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path>
              <rect width="4" height="12" x="2" y="9"></rect>
              <circle cx="4" cy="4" r="2"></circle>
            </svg>
            <span>LinkedIn</span>
          </a>
        )}
        <a href="https://github.com/Stan69000" target="_blank" rel="noopener noreferrer" class="social-link" aria-label="GitHub">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path>
          </svg>
          <span>GitHub</span>
        </a>
      </div>
    </div>

    <div class="site-footer__bottom">
      <p class="footer-copyright">{footerText}</p>
      <p class="footer-built">{footerConfig.built_with || 'Site réalisé par Stan Bouchet'}</p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: auto;
    padding: 3.5rem 0 2rem;
    border-top: 1px solid var(--line);
    background: linear-gradient(180deg, color-mix(in srgb, var(--surface) 88%, transparent), var(--surface));
  }

  .site-footer__inner {
    display: grid;
    gap: 2rem;
  }

  .site-footer__top {
    display: grid;
    gap: 1.75rem;
    grid-template-columns: 1.4fr 1.2fr 1fr;
    align-items: start;
    padding: 1.5rem;
    border: 1px solid var(--line);
    border-radius: 1.1rem;
    background: color-mix(in srgb, var(--bg) 92%, transparent);
    box-shadow: var(--shadow);
  }

  .footer-brand {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    color: var(--text);
    text-decoration: none;
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 1.05rem;
    transition: opacity var(--transition);
  }

  .footer-brand:hover {
    opacity: 0.78;
  }

  .footer-brand svg {
    color: var(--accent);
  }

  .site-footer__nav {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.55rem 0.85rem;
  }

  .site-footer__nav a {
    color: var(--text);
    text-decoration: none;
    font-size: var(--text-sm);
    font-weight: 500;
    width: fit-content;
    border-bottom: 1px solid transparent;
    transition: border-color var(--transition), color var(--transition);
  }

  .site-footer__nav a:hover {
    border-color: var(--accent);
    color: var(--accent);
  }

  .site-footer__social {
    display: grid;
    gap: 0.6rem;
    align-content: start;
  }

  .social-link {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    color: var(--text);
    text-decoration: none;
    font-size: var(--text-sm);
    font-weight: 500;
    transition: color var(--transition);
    width: fit-content;
  }

  .social-link:hover {
    color: var(--accent);
  }

  .site-footer__bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    padding: 0 0.35rem;
    color: var(--muted);
    font-size: var(--text-xs);
  }

  .footer-copyright,
  .footer-built {
    margin: 0;
  }

  @media (max-width: 980px) {
    .site-footer__top {
      grid-template-columns: 1fr;
    }

    .site-footer__nav {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  @media (max-width: 640px) {
    .site-footer {
      padding-top: 2.75rem;
    }

    .site-footer__top {
      padding: 1.1rem;
    }

    .site-footer__nav {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .site-footer__bottom {
      flex-direction: column;
      align-items: flex-start;
      padding: 0;
      gap: 0.4rem;
    }
  }
</style>
