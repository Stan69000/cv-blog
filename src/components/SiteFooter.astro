---
import siteConfig from '../data/site.json';
import socialConfig from '../data/social.json';
import footerConfig from '../data/footer.json';

const currentYear = new Date().getFullYear();
const footerText = (footerConfig.copyright || '{year}').replace('{year}', currentYear.toString());

const navLinks = [
  { href: '/', label: 'Accueil' },
  { href: '/parcours', label: 'Parcours' },
  { href: '/projets', label: 'Projets' },
  { href: '/engagement-associatif', label: 'Engagement' },
  { href: '/blog', label: 'Blog' },
  { href: '/contact', label: 'Contact' },
];
---

<footer class="site-footer">
  <div class="container site-footer__inner">

    <div class="footer-card">
      <div class="footer-col footer-col--brand">
        <a href="/" class="footer-brand" aria-label="Accueil - Stan Bouchet">
          <svg width="26" height="26" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <rect width="32" height="32" rx="8" fill="currentColor" fill-opacity="0.1"/>
            <path d="M8 12h16M8 16h12M8 20h8" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
          </svg>
          <span>{siteConfig.title}</span>
        </a>
        <p class="footer-desc">{siteConfig.description}</p>
      </div>

      <div class="footer-col">
        <p class="footer-label">Navigation</p>
        <nav aria-label="Navigation footer">
          <ul class="footer-nav-list">
            {navLinks.map((link) => (
              <li><a href={link.href}>{link.label}</a></li>
            ))}
          </ul>
        </nav>
      </div>

      <div class="footer-col footer-col--social">
        <p class="footer-label">Retrouvez-moi</p>
        <div class="social-links">
          {socialConfig.linkedin && (
            <a href={socialConfig.linkedin} target="_blank" rel="noopener noreferrer" class="social-link" aria-label="LinkedIn">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path>
                <rect width="4" height="12" x="2" y="9"></rect>
                <circle cx="4" cy="4" r="2"></circle>
              </svg>
              <span>LinkedIn</span>
            </a>
          )}
          <a href={socialConfig.github || 'https://github.com/Stan69000'} target="_blank" rel="noopener noreferrer" class="social-link" aria-label="GitHub">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path>
            </svg>
            <span>GitHub</span>
          </a>
        </div>
        <a href="/cv" class="footer-cv">Voir le CV →</a>
      </div>
    </div>

    <div class="footer-bottom">
      <p>{footerText}</p>
      <a href="/sitemap.xml" class="footer-sitemap">Plan du site</a>
    </div>

  </div>
</footer>

<style>
  .site-footer {
    margin-top: auto;
    padding: 3rem 0 1.75rem;
  }

  .site-footer__inner {
    display: grid;
    gap: 0;
  }

  .footer-card {
    display: grid;
    gap: 2rem;
    grid-template-columns: 1.6fr 1fr 1fr;
    align-items: start;
    padding: 1.75rem 2rem;
    border: 1px solid var(--line);
    border-radius: 1.25rem;
    background:
      radial-gradient(circle at 5% 50%, color-mix(in srgb, var(--accent) 7%, transparent), transparent 55%),
      color-mix(in srgb, var(--bg) 92%, transparent);
    box-shadow: var(--shadow);
  }

  .footer-col--brand {
    display: grid;
    gap: 0.85rem;
    align-content: start;
  }

  .footer-brand {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    color: var(--text);
    text-decoration: none;
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 1.05rem;
    width: fit-content;
    transition: opacity var(--transition);
  }

  .footer-brand:hover {
    opacity: 0.75;
  }

  .footer-brand svg {
    color: var(--accent);
    flex-shrink: 0;
  }

  .footer-desc {
    margin: 0;
    font-size: var(--text-xs);
    line-height: 1.6;
    color: var(--muted);
    max-width: 26ch;
  }

  .footer-label {
    margin: 0 0 0.85rem;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--muted);
  }

  .footer-nav-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.5rem;
  }

  .footer-nav-list a {
    color: var(--text);
    text-decoration: none;
    font-size: var(--text-sm);
    font-weight: 500;
    width: fit-content;
    opacity: 0.78;
    transition: opacity var(--transition), color var(--transition);
  }

  .footer-nav-list a:hover {
    opacity: 1;
    color: var(--accent);
  }

  .footer-col--social {
    display: grid;
    gap: 0;
    align-content: start;
  }

  .social-links {
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
    margin-bottom: 1.25rem;
  }

  .social-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.42rem 0.72rem 0.42rem 0.6rem;
    border: 1px solid color-mix(in srgb, var(--line) 75%, transparent);
    border-radius: 999px;
    font-size: var(--text-xs);
    font-weight: 500;
    color: var(--muted);
    text-decoration: none;
    width: fit-content;
    transition: color var(--transition), border-color var(--transition), background var(--transition);
  }

  .social-link:hover {
    color: var(--text);
    border-color: color-mix(in srgb, var(--accent) 55%, transparent);
    background: color-mix(in srgb, var(--accent) 6%, transparent);
  }

  .footer-cv {
    display: inline-flex;
    align-items: center;
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--accent);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: border-color var(--transition);
  }

  .footer-cv:hover {
    border-color: var(--accent);
  }

  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    padding: 1.1rem 0.25rem 0;
    color: var(--muted);
    font-size: var(--text-xs);
  }

  .footer-bottom p {
    margin: 0;
  }

  .footer-sitemap {
    color: var(--muted);
    text-decoration: none;
    font-size: var(--text-xs);
    border-bottom: 1px solid transparent;
    transition: color var(--transition), border-color var(--transition);
  }

  .footer-sitemap:hover {
    color: var(--text);
    border-color: color-mix(in srgb, var(--line) 80%, transparent);
  }

  @media (max-width: 980px) {
    .footer-card {
      grid-template-columns: 1fr 1fr;
    }

    .footer-col--brand {
      grid-column: 1 / -1;
      flex-direction: row;
      gap: 1.5rem;
    }

    .footer-desc {
      max-width: none;
    }
  }

  @media (max-width: 640px) {
    .site-footer {
      padding-top: 2.5rem;
    }

    .footer-card {
      grid-template-columns: 1fr;
      padding: 1.25rem 1.35rem;
      gap: 1.5rem;
    }

    .footer-col--brand {
      grid-column: auto;
    }

    .footer-bottom {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.35rem;
    }
  }
</style>
