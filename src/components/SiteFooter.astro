---
import siteConfig from '../data/site.json';
import socialConfig from '../data/social.json';
import footerConfig from '../data/footer.json';

const currentYear = new Date().getFullYear();
const footerText = (footerConfig.copyright || '{year}').replace('{year}', currentYear.toString());
---

<footer class="site-footer">
  <div class="container site-footer__inner">
    <div class="site-footer__brand">
      <a href="/" class="footer-brand">
        <svg width="24" height="24" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <rect width="32" height="32" rx="8" fill="currentColor" fill-opacity="0.1"/>
          <path d="M8 12h16M8 16h12M8 20h8" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
        </svg>
        <span>{siteConfig.title}</span>
      </a>
      <p class="footer-tagline">{siteConfig.tagline}</p>
    </div>

    <nav class="site-footer__nav" aria-label="Navigation footer">
      <div class="footer-nav__group">
        <h3 class="footer-nav__title">Navigation</h3>
        <ul class="footer-nav__list">
          <li><a href="/parcours">Parcours</a></li>
          <li><a href="/projets">Projets</a></li>
          <li><a href="/engagement-associatif">Engagement</a></li>
          <li><a href="/blog">Blog</a></li>
        </ul>
      </div>
      <div class="footer-nav__group">
        <h3 class="footer-nav__title">Contact</h3>
        <ul class="footer-nav__list">
          {socialConfig.email && (
            <li>
              <a href={`mailto:${socialConfig.email}`}>
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <rect width="20" height="16" x="2" y="4" rx="2"></rect>
                  <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path>
                </svg>
                Email
              </a>
            </li>
          )}
          {socialConfig.linkedin && (
            <li>
              <a href={socialConfig.linkedin} target="_blank" rel="noopener noreferrer">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path>
                  <rect width="4" height="12" x="2" y="9"></rect>
                  <circle cx="4" cy="4" r="2"></circle>
                </svg>
                LinkedIn
              </a>
            </li>
          )}
        </ul>
      </div>
    </nav>

    <div class="site-footer__bottom">
      <p class="footer-copyright">{footerText}</p>
      <p class="footer-built">
        {footerConfig.built_with || 'Construit avec Astro'}
        <span class="footer-divider">·</span>
        <a href="/admin/">Administration</a>
      </p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: auto;
    padding: 3rem 0 2rem;
    border-top: 1px solid var(--line);
    background: var(--surface);
  }

  .site-footer__inner {
    display: grid;
    gap: 2rem;
  }

  @media (min-width: 768px) {
    .site-footer__inner {
      grid-template-columns: 1fr auto;
      gap: 3rem;
    }
  }

  .site-footer__brand {
    max-width: 280px;
  }

  .footer-brand {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    color: var(--text);
    text-decoration: none;
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 1rem;
    transition: opacity var(--transition);
  }

  .footer-brand:hover {
    opacity: 0.7;
  }

  .footer-brand svg {
    color: var(--accent);
  }

  .footer-tagline {
    margin: 0.5rem 0 0;
    font-size: 0.8125rem;
    color: var(--muted);
    line-height: 1.5;
  }

  .site-footer__nav {
    display: flex;
    gap: 2.5rem;
  }

  @media (max-width: 767px) {
    .site-footer__nav {
      gap: 2rem;
    }
  }

  .footer-nav__title {
    margin: 0 0 0.75rem;
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--muted);
  }

  .footer-nav__list {
    margin: 0;
    padding: 0;
    list-style: none;
    display: grid;
    gap: 0.5rem;
  }

  .footer-nav__list a {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.875rem;
    color: var(--text);
    text-decoration: none;
    transition: color var(--transition);
  }

  .footer-nav__list a:hover {
    color: var(--accent);
  }

  .site-footer__bottom {
    padding-top: 1.5rem;
    border-top: 1px solid var(--line);
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1rem;
    justify-content: space-between;
    align-items: center;
  }

  @media (min-width: 768px) {
    .site-footer__bottom {
      grid-column: 1 / -1;
    }
  }

  .footer-copyright,
  .footer-built {
    margin: 0;
    font-size: 0.8125rem;
    color: var(--muted);
  }

  .footer-built {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .footer-divider {
    opacity: 0.5;
  }

  .footer-built a {
    color: var(--accent);
    text-decoration: none;
    transition: opacity var(--transition);
  }

  .footer-built a:hover {
    opacity: 0.8;
  }
</style>
