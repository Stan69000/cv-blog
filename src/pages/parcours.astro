---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import parcoursData from '../data/parcours.json';

const indyStartDate = new Date(parcoursData.indyStart.year, parcoursData.indyStart.month - 1, 1);
const today = new Date();
const totalMonthsAtIndy = Math.max(1, (today.getFullYear() - indyStartDate.getFullYear()) * 12 + (today.getMonth() - indyStartDate.getMonth()) + 1);
const indyYears = Math.floor(totalMonthsAtIndy / 12);
const indyMonths = totalMonthsAtIndy % 12;
const indyDuration = [indyYears > 0 ? `${indyYears} an${indyYears > 1 ? 's' : ''}` : '', indyMonths > 0 ? `${indyMonths} mois` : ''].filter(Boolean).join(' ');
const indyHeroLabel = `Indy · CDI · ${indyDuration} (depuis juillet ${parcoursData.indyStart.year})`;
const monthYearFormatter = new Intl.DateTimeFormat('fr-FR', {
  month: 'short',
  year: 'numeric'
});

function toMonthDate(year: number, month: number) {
  return new Date(year, month - 1, 1);
}

function getTotalMonthsInclusive(startDate: Date, endDate: Date) {
  return Math.max(
    1,
    (endDate.getFullYear() - startDate.getFullYear()) * 12 +
      (endDate.getMonth() - startDate.getMonth()) +
      1
  );
}

function formatDuration(startDate: Date, endDate: Date) {
  const totalMonths = getTotalMonthsInclusive(startDate, endDate);
  const years = Math.floor(totalMonths / 12);
  const months = totalMonths % 12;
  const parts = [];

  if (years > 0) {
    parts.push(`${years} an${years > 1 ? 's' : ''}`);
  }

  if (months > 0) {
    parts.push(`${months} mois`);
  }

  return parts.join(' ');
}

function formatPeriod(startDate: Date, endDate?: Date) {
  const start = monthYearFormatter.format(startDate);
  const end = endDate ? monthYearFormatter.format(endDate) : 'aujourd’hui';
  return `${start} - ${end}`;
}

const quickStats = parcoursData.quickStats;
const currentScope = parcoursData.currentScope;
const stack = parcoursData.stack;
const experiences = parcoursData.experiences.map((xp) => {
  const startDate = toMonthDate(xp.start.year, xp.start.month);
  const endDate = xp.end ? toMonthDate(xp.end.year, xp.end.month) : undefined;
  return {
    ...xp,
    startDate,
    endDate,
    period: formatPeriod(startDate, endDate),
    duration: formatDuration(startDate, endDate ?? today)
  };
});
---

<BaseLayout
  title="Parcours pro | Stan Bouchet"
  description="Parcours professionnel de Stan Bouchet: évolution, responsabilités, impacts et expériences clés."
  ogImage="/images/og/parcours.jpg"
>
  <SiteHeader />

  <main id="main-content" class="container section universe universe--pro">
    <section class="hero section" aria-labelledby="hero-title">
      <div class="hero-panel">
        <p class="eyebrow">{parcoursData.heroEyebrow}</p>
        <h1 id="hero-title">{parcoursData.heroTitle}</h1>
        <p class="lead muted">{parcoursData.heroLead}</p>
        <div class="hero-cta">
          <a href={parcoursData.heroLinkedinUrl} target="_blank" rel="noopener noreferrer">{parcoursData.heroLinkedinLabel}</a>
          <p>{indyHeroLabel}</p>
        </div>
      </div>
    </section>

    <section class="section" aria-labelledby="impact-title">
      <h2 id="impact-title">{parcoursData.impactTitle}</h2>
      <ul class="stats-grid" aria-label="Indicateurs clés de carrière">
        {quickStats.map((item) => (
          <li>
            <p class="value">{item.value}</p>
            <p class="label">{item.label}</p>
          </li>
        ))}
      </ul>
    </section>

    <section class="section" aria-labelledby="scope-title">
      <h2 id="scope-title">{parcoursData.scopeTitle}</h2>
      <div class="scope-grid">
        {currentScope.map((item) => (
          <article class="scope-card">
            <h3>{item.title}</h3>
            <p>{item.text}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="section" aria-labelledby="timeline-title">
      <h2 id="timeline-title">{parcoursData.timelineTitle}</h2>
      <ol class="career-timeline">
        {experiences.map((xp) => (
          <li>
            <article class="xp-card">
              <header class="xp-header">
                <div>
                  <p class="xp-role">{xp.role}</p>
                  <p class="xp-company">{xp.company} · {xp.contract}</p>
                </div>
                <p class="xp-duration">{xp.duration}</p>
              </header>

              <div class="xp-meta">
                <span>{xp.period}</span>
                <span>{xp.location}</span>
                <span>{xp.mode}</span>
              </div>

              <p class="xp-summary">{xp.summary}</p>

              <ul class="xp-list">
                {xp.highlights.map((highlight) => (
                  <li>{highlight}</li>
                ))}
              </ul>
            </article>
          </li>
        ))}
      </ol>
    </section>

    <section class="section" aria-labelledby="stack-title">
      <h2 id="stack-title">{parcoursData.stackTitle}</h2>
      <ul class="tags tags--large" aria-label="Stack et outils utilisés">
        {stack.map((tool) => (
          <li>{tool}</li>
        ))}
      </ul>
    </section>
  </main>

  <SiteFooter />
</BaseLayout>

<style>
  .hero {
    display: block;
    min-height: auto;
    grid-template-columns: 1fr;
    padding-top: 1rem;
  }

  .hero-panel {
    border: 1px solid var(--line);
    background:
      radial-gradient(circle at 10% 15%, color-mix(in srgb, var(--accent) 16%, transparent), transparent 42%),
      radial-gradient(circle at 86% 84%, color-mix(in srgb, var(--accent-2) 18%, transparent), transparent 45%),
      var(--surface);
    border-radius: calc(var(--radius) + 0.25rem);
    box-shadow: var(--shadow);
    padding: clamp(1.25rem, 3vw, 2rem);
  }

  .hero h1 {
    margin-top: 0.55rem;
    width: 100%;
  }

  .hero .lead {
    margin-top: 1rem;
    max-width: 100%;
  }

  .hero-cta {
    margin-top: 1.2rem;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.8rem 1rem;
  }

  .hero-cta a {
    text-decoration: none;
    border: 1px solid color-mix(in srgb, var(--accent) 45%, var(--line));
    background: color-mix(in srgb, var(--accent) 12%, var(--surface));
    color: var(--text);
    padding: 0.55rem 0.9rem;
    border-radius: 999px;
    font-size: var(--text-sm);
    font-weight: 600;
    transition: transform var(--transition), border-color var(--transition);
  }

  .hero-cta a:hover {
    transform: translateY(-1px);
    border-color: var(--accent);
  }

  .hero-cta p {
    color: var(--muted);
    font-size: var(--text-xs);
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 0.9rem;
    list-style: none;
    padding: 0;
  }

  .stats-grid li {
    border: 1px solid var(--line);
    background: var(--surface);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
    padding: 1rem 1.05rem;
  }

  .stats-grid .value {
    font-family: var(--font-heading);
    font-size: clamp(1.5rem, 3vw, 2.1rem);
    line-height: 1;
    margin-bottom: 0.35rem;
  }

  .stats-grid .label {
    color: var(--muted);
    font-size: var(--text-xs);
    line-height: 1.35;
  }

  .scope-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }

  .scope-card {
    border: 1px solid var(--line);
    background: var(--surface);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
    padding: 1.1rem 1.2rem;
  }

  .scope-card h3 {
    margin-bottom: 0.45rem;
  }

  .career-timeline {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 1rem;
    position: relative;
  }

  .career-timeline::before {
    content: '';
    position: absolute;
    left: 1.05rem;
    top: 0.5rem;
    bottom: 0.5rem;
    width: 2px;
    background: linear-gradient(
      to bottom,
      color-mix(in srgb, var(--accent) 60%, transparent),
      color-mix(in srgb, var(--accent-2) 44%, transparent)
    );
  }

  .career-timeline > li {
    position: relative;
    padding-left: 2.2rem;
  }

  .career-timeline > li::before {
    content: '';
    position: absolute;
    left: 0.73rem;
    top: 1.15rem;
    width: 0.7rem;
    height: 0.7rem;
    border-radius: 999px;
    background: var(--surface-strong);
    border: 2px solid var(--accent);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--accent) 20%, transparent);
  }

  .xp-card {
    border: 1px solid var(--line);
    background: var(--surface);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
    padding: 1.1rem 1.2rem;
  }

  .xp-header {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    align-items: baseline;
    margin-bottom: 0.35rem;
  }

  .xp-role {
    font-family: var(--font-heading);
    font-size: clamp(1.25rem, 2vw, 1.55rem);
    line-height: 1.1;
  }

  .xp-company {
    margin-top: 0.25rem;
    color: var(--muted);
    font-size: var(--text-xs);
  }

  .xp-duration {
    font-size: var(--text-xs);
    color: var(--muted);
    white-space: nowrap;
    border: 1px solid color-mix(in srgb, var(--line) 85%, transparent);
    border-radius: 999px;
    padding: 0.2rem 0.55rem;
  }

  .xp-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-bottom: 0.75rem;
  }

  .xp-meta span {
    font-size: 0.79rem;
    color: var(--muted);
    border: 1px dashed color-mix(in srgb, var(--line) 85%, transparent);
    border-radius: 999px;
    padding: 0.16rem 0.52rem;
  }

  .xp-summary {
    margin-bottom: 0.75rem;
  }

  .xp-list {
    margin: 0;
    padding-left: 1.15rem;
    display: grid;
    gap: 0.34rem;
  }

  .xp-list li::marker {
    color: var(--accent);
  }

  @media (max-width: 980px) {
    .stats-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 780px) {
    .scope-grid {
      grid-template-columns: 1fr;
    }

    .xp-header {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.5rem;
    }
  }

  @media (max-width: 640px) {
    .stats-grid {
      grid-template-columns: 1fr;
    }

    .career-timeline::before {
      left: 0.85rem;
    }

    .career-timeline > li {
      padding-left: 1.8rem;
    }

    .career-timeline > li::before {
      left: 0.55rem;
    }
  }
</style>
