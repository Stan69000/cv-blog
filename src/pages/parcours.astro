---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';

const quickStats = [
  { value: '21+', label: "ans d'expérience opérationnelle" },
  { value: '300+', label: 'collaborateurs gérés chez Indy' },
  { value: 'Plusieurs centaines', label: 'd’ordinateurs configurés depuis mes débuts chez Indy' },
  { value: '1/mois', label: 'session outils + sécurité animée' }
];

const currentScope = [
  {
    title: 'Pilotage IT autonome',
    text: 'Gestion complète du parc, des accès, des outils et du support pour plus de 300 collaborateurs.'
  },
  {
    title: 'Structuration & qualité',
    text: 'SLA, documentation, process, gouvernance des usages et amélioration continue des pratiques.'
  },
  {
    title: 'Automatisation pragmatique',
    text: 'Réduction des frictions quotidiennes avec des automatisations utiles, ciblées et maintenables.'
  },
  {
    title: 'Accompagnement des équipes',
    text: 'Onboarding, offboarding, formation et pédagogie pour rendre l’IT lisible et autonome.'
  }
];

const stack = [
  'Slack',
  'Notion',
  '1Password',
  'Google Workspace',
  'IA générative',
  'MDM',
  'macOS / Windows / Linux',
  'Documentation',
  'Automatisation',
  'Sensibilisation sécurité'
];

const experiences = [
  {
    role: 'Information Technology Officer',
    company: 'Indy',
    contract: 'CDI',
    period: 'janv. 2024 - aujourd’hui',
    duration: '2 ans 4 mois',
    location: 'Lyon, Auvergne-Rhône-Alpes, France',
    mode: 'Hybride',
    summary:
      'Fonction créée sur mesure après une évolution interne depuis le helpdesk. Responsable IT autonome, avec un périmètre transverse en forte croissance.',
    highlights: [
      'Gestion autonome d’un parc de plus de 300 collaborateurs.',
      'Développement de la fonction IT au rythme de la croissance de l’entreprise.',
      'Structuration durable du support, des outils et des standards de service.'
    ]
  },
  {
    role: 'Technicien Helpdesk',
    company: 'Indy',
    contract: 'CDI',
    period: 'juil. 2022 - janv. 2024',
    duration: '1 an 7 mois',
    location: 'Lyon, Auvergne-Rhône-Alpes, France',
    mode: 'Sur site / Hybride',
    summary:
      'Premier collaborateur IT recruté chez Indy en 2022. Construction des bases opérationnelles du support et de l’environnement de travail.',
    highlights: [
      'Support utilisateur, comptes, droits d’accès, onboarding et offboarding.',
      'Configuration de plus de 400 ordinateurs en 2,5 ans et gestion du parc multi-OS.',
      'Administration Slack, Notion, 1Password et Google Workspace.',
      'Déploiement et pilotage de la solution MDM.',
      'Formation mensuelle des nouveaux collaborateurs sur les outils et la sécurité.',
      'Mise en place de documentation, automatisations et amélioration des processus.',
      'Responsable achats IT et SAV matériel.',
      'Contributions transverses: RSE, office management, CSE, captation évènementielle, SST.'
    ]
  },
  {
    role: 'Manager de proximité',
    company: 'Carsat Rhône Alpes',
    contract: 'Mission',
    period: 'janv. 2022 - mars 2022',
    duration: '3 mois',
    location: 'Lyon, Auvergne-Rhône-Alpes, France',
    mode: 'Sur site',
    summary:
      'Management d’équipe dans un environnement de flux opérationnels exigeants.',
    highlights: [
      'Management direct de 20 techniciens et gestionnaires traitement de l’information.',
      'Coordination transverse de l’encadrement pour superviser les flux de 82 collaborateurs.',
      'Formations suivies: Manager Coach, entretiens individuels, management des télétravailleurs.'
    ]
  },
  {
    role: "Agent de maîtrise - Chef d'équipe adjoint",
    company: 'EURO.TVS - TRAITEMENT VALEURS SERVICES',
    contract: 'CDI',
    period: 'avr. 2005 - déc. 2021',
    duration: '16 ans 9 mois',
    location: 'Tassin, Auvergne-Rhône-Alpes, France',
    mode: 'Sur site',
    summary:
      'Responsabilités opérationnelles et encadrement adjoint dans le traitement de documents et de données associées aux moyens de paiement.',
    highlights: [
      'Encadrement adjoint d’une équipe de 15 personnes.',
      'Pilotage d’activités: numérisation, saisie de masse, enrichissement, archivage et restitution.',
      'Suivi incidents, supervision technique matérielle et logicielle.',
      'Gestion des réclamations clients et suivi de tableaux de bord.',
      'Formation des nouveaux arrivants et documentation qualité (procédures, mémos).' 
    ]
  },
  {
    role: 'Travailleur indépendant',
    company: 'Monkey of The Net',
    contract: 'Indépendant',
    period: 'janv. 2009 - déc. 2011',
    duration: '3 ans',
    location: 'Toussieu, Auvergne-Rhône-Alpes, France',
    mode: 'Freelance',
    summary:
      'Création de sites web et prestations multimédia en autonomie, de la conception à la maintenance.',
    highlights: [
      'Création de sites sur base Joomla et WordPress, adaptés aux besoins clients.',
      'Création de chartes graphiques, maintenance et hébergement.',
      'Production de diaporamas photo et rendus vidéo/DVD/exécutable.'
    ]
  },
  {
    role: 'Agent de sécurité',
    company: 'Sécurifrance',
    contract: 'Temps plein',
    period: 'oct. 2004 - avr. 2005',
    duration: '7 mois',
    location: 'Lyon et périphérie',
    mode: 'Terrain',
    summary:
      'Expérience de terrain structurante sur la rigueur, l’autonomie et la gestion de situations sensibles.',
    highlights: [
      'Gardes de 12 heures en autonomie et rondes intérieures/extérieures.',
      'Utilisation d’outils d’alarme, vidéosurveillance et logiciels de compte rendu.',
      'Interventions sur sites industriels et tertiaires exigeants.'
    ]
  }
];
---

<BaseLayout
  title="Parcours pro | Stan Bouchet"
  description="Parcours professionnel de Stan Bouchet: évolution, responsabilités, impacts et expériences clés."
>
  <SiteHeader />

  <main id="main-content" class="container section universe universe--pro">
    <section class="hero section" aria-labelledby="hero-title">
      <div class="hero-panel">
        <p class="eyebrow">Parcours professionnel</p>
        <h1 id="hero-title">Une carrière construite sur le terrain, structurée par l’impact.</h1>
        <p class="lead muted">
          De l’opérationnel au pilotage IT, avec une constante: rendre les outils, les usages et les process
          plus simples, plus fiables et plus utiles pour les équipes.
        </p>
        <div class="hero-cta">
          <a href="https://www.linkedin.com/in/stanislas-bouchet/" target="_blank" rel="noopener noreferrer">Voir le profil LinkedIn</a>
          <p>Indy · CDI · 3 ans 10 mois (depuis juillet 2022)</p>
        </div>
      </div>
    </section>

    <section class="section" aria-labelledby="impact-title">
      <h2 id="impact-title">Impact en un coup d’œil</h2>
      <ul class="stats-grid" aria-label="Indicateurs clés de carrière">
        {quickStats.map((item) => (
          <li>
            <p class="value">{item.value}</p>
            <p class="label">{item.label}</p>
          </li>
        ))}
      </ul>
    </section>

    <section class="section" aria-labelledby="scope-title">
      <h2 id="scope-title">Ce que je pilote aujourd’hui</h2>
      <div class="scope-grid">
        {currentScope.map((item) => (
          <article class="scope-card">
            <h3>{item.title}</h3>
            <p>{item.text}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="section" aria-labelledby="timeline-title">
      <h2 id="timeline-title">Timeline de carrière</h2>
      <ol class="career-timeline">
        {experiences.map((xp) => (
          <li>
            <article class="xp-card">
              <header class="xp-header">
                <div>
                  <p class="xp-role">{xp.role}</p>
                  <p class="xp-company">{xp.company} · {xp.contract}</p>
                </div>
                <p class="xp-duration">{xp.duration}</p>
              </header>

              <div class="xp-meta">
                <span>{xp.period}</span>
                <span>{xp.location}</span>
                <span>{xp.mode}</span>
              </div>

              <p class="xp-summary">{xp.summary}</p>

              <ul class="xp-list">
                {xp.highlights.map((highlight) => (
                  <li>{highlight}</li>
                ))}
              </ul>
            </article>
          </li>
        ))}
      </ol>
    </section>

    <section class="section" aria-labelledby="stack-title">
      <h2 id="stack-title">Environnement de travail</h2>
      <ul class="tags tags--large" aria-label="Stack et outils utilisés">
        {stack.map((tool) => (
          <li>{tool}</li>
        ))}
      </ul>
    </section>
  </main>

  <SiteFooter />
</BaseLayout>

<style>
  .hero {
    display: block;
    min-height: auto;
    grid-template-columns: 1fr;
    padding-top: 1rem;
  }

  .hero-panel {
    border: 1px solid var(--line);
    background:
      radial-gradient(circle at 10% 15%, color-mix(in srgb, var(--accent) 16%, transparent), transparent 42%),
      radial-gradient(circle at 86% 84%, color-mix(in srgb, var(--accent-2) 18%, transparent), transparent 45%),
      var(--surface);
    border-radius: calc(var(--radius) + 0.25rem);
    box-shadow: var(--shadow);
    padding: clamp(1.25rem, 3vw, 2rem);
  }

  .hero h1 {
    margin-top: 0.55rem;
    width: 100%;
  }

  .hero .lead {
    margin-top: 1rem;
    max-width: 100%;
  }

  .hero-cta {
    margin-top: 1.2rem;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.8rem 1rem;
  }

  .hero-cta a {
    text-decoration: none;
    border: 1px solid color-mix(in srgb, var(--accent) 45%, var(--line));
    background: color-mix(in srgb, var(--accent) 12%, var(--surface));
    color: var(--text);
    padding: 0.55rem 0.9rem;
    border-radius: 999px;
    font-size: var(--text-sm);
    font-weight: 600;
    transition: transform var(--transition), border-color var(--transition);
  }

  .hero-cta a:hover {
    transform: translateY(-1px);
    border-color: var(--accent);
  }

  .hero-cta p {
    color: var(--muted);
    font-size: var(--text-xs);
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 0.9rem;
    list-style: none;
    padding: 0;
  }

  .stats-grid li {
    border: 1px solid var(--line);
    background: var(--surface);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
    padding: 1rem 1.05rem;
  }

  .stats-grid .value {
    font-family: var(--font-heading);
    font-size: clamp(1.5rem, 3vw, 2.1rem);
    line-height: 1;
    margin-bottom: 0.35rem;
  }

  .stats-grid .label {
    color: var(--muted);
    font-size: var(--text-xs);
    line-height: 1.35;
  }

  .scope-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }

  .scope-card {
    border: 1px solid var(--line);
    background: var(--surface);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
    padding: 1.1rem 1.2rem;
  }

  .scope-card h3 {
    margin-bottom: 0.45rem;
  }

  .career-timeline {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 1rem;
    position: relative;
  }

  .career-timeline::before {
    content: '';
    position: absolute;
    left: 1.05rem;
    top: 0.5rem;
    bottom: 0.5rem;
    width: 2px;
    background: linear-gradient(
      to bottom,
      color-mix(in srgb, var(--accent) 60%, transparent),
      color-mix(in srgb, var(--accent-2) 44%, transparent)
    );
  }

  .career-timeline > li {
    position: relative;
    padding-left: 2.2rem;
  }

  .career-timeline > li::before {
    content: '';
    position: absolute;
    left: 0.73rem;
    top: 1.15rem;
    width: 0.7rem;
    height: 0.7rem;
    border-radius: 999px;
    background: var(--surface-strong);
    border: 2px solid var(--accent);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--accent) 20%, transparent);
  }

  .xp-card {
    border: 1px solid var(--line);
    background: var(--surface);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
    padding: 1.1rem 1.2rem;
  }

  .xp-header {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    align-items: baseline;
    margin-bottom: 0.35rem;
  }

  .xp-role {
    font-family: var(--font-heading);
    font-size: clamp(1.25rem, 2vw, 1.55rem);
    line-height: 1.1;
  }

  .xp-company {
    margin-top: 0.25rem;
    color: var(--muted);
    font-size: var(--text-xs);
  }

  .xp-duration {
    font-size: var(--text-xs);
    color: var(--muted);
    white-space: nowrap;
    border: 1px solid color-mix(in srgb, var(--line) 85%, transparent);
    border-radius: 999px;
    padding: 0.2rem 0.55rem;
  }

  .xp-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-bottom: 0.75rem;
  }

  .xp-meta span {
    font-size: 0.79rem;
    color: var(--muted);
    border: 1px dashed color-mix(in srgb, var(--line) 85%, transparent);
    border-radius: 999px;
    padding: 0.16rem 0.52rem;
  }

  .xp-summary {
    margin-bottom: 0.75rem;
  }

  .xp-list {
    margin: 0;
    padding-left: 1.15rem;
    display: grid;
    gap: 0.34rem;
  }

  .xp-list li::marker {
    color: var(--accent);
  }

  @media (max-width: 980px) {
    .stats-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 780px) {
    .scope-grid {
      grid-template-columns: 1fr;
    }

    .xp-header {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.5rem;
    }
  }

  @media (max-width: 640px) {
    .stats-grid {
      grid-template-columns: 1fr;
    }

    .career-timeline::before {
      left: 0.85rem;
    }

    .career-timeline > li {
      padding-left: 1.8rem;
    }

    .career-timeline > li::before {
      left: 0.55rem;
    }
  }
</style>
