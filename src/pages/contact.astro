---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';

const linkedInUrl = 'https://www.linkedin.com/in/stanislas-bouchet/';
const githubUrl = 'https://github.com/Stan69000';
---

<BaseLayout
  title="Contact | Stan Bouchet"
  description="Contactez Stan Bouchet via LinkedIn ou GitHub. Disponible pour des échanges sur les projets web, l'IT terrain, l'accessibilité et les sujets associatifs."
  ogImage="/images/og/contact.jpg"
>
  <SiteHeader />

  <main id="main-content" class="container section contact-page">
    <section class="contact-hero section">
      <div class="hero-panel">
        <p class="eyebrow">Contact</p>
        <h1>Prenons contact.</h1>
        <p class="lead muted">
          Le meilleur canal reste LinkedIn pour un premier échange.
          Je réponds généralement sous 2-3 jours aux messages liés aux projets web,
          à l'IT terrain, à l'accessibilité et aux sujets associatifs.
        </p>
        <p class="contact-hero__cta">
          <a class="button button--primary" href={linkedInUrl} target="_blank" rel="noopener noreferrer">
            Écrire sur LinkedIn
          </a>
          <a class="button" href={githubUrl} target="_blank" rel="noopener noreferrer">
            Voir GitHub
          </a>
        </p>
      </div>
    </section>

    <section class="section contact-grid" aria-labelledby="contact-info-title">
      <h2 id="contact-info-title" class="sr-only">Informations de contact</h2>

      <article class="contact-card contact-card--highlight">
        <p class="contact-card__icon" aria-hidden="true">💼</p>
        <h3>LinkedIn</h3>
        <p>
          <a href={linkedInUrl} target="_blank" rel="noopener noreferrer">linkedin.com/in/stanislas-bouchet</a>
        </p>
        <p class="muted">Pour les échanges pro, projets et collaborations associatives.</p>
      </article>

      <article class="contact-card">
        <p class="contact-card__icon" aria-hidden="true">🛠️</p>
        <h3>GitHub</h3>
        <p>
          <a href={githubUrl} target="_blank" rel="noopener noreferrer">github.com/Stan69000</a>
        </p>
        <p class="muted">Pour les projets open source : issues, contributions, retours.</p>
      </article>

    </section>
  </main>

  <SiteFooter />
</BaseLayout>

<style>
  .contact-page {
    padding-top: 1rem;
    padding-bottom: 3rem;
  }

  .contact-hero {
    display: block;
    min-height: auto;
    padding-top: 0;
  }

  .contact-hero h1 {
    width: 100%;
  }

  .contact-hero__cta {
    margin-top: 1.25rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.7rem;
  }

  .button--primary {
    background: var(--accent);
    color: var(--accent-contrast);
    border-color: var(--accent);
  }

  .button--primary:hover {
    background: color-mix(in srgb, var(--accent) 85%, var(--text));
    border-color: color-mix(in srgb, var(--accent) 85%, var(--text));
  }

  .contact-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }

  .contact-card {
    border: 1px solid var(--line);
    background: var(--surface);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
    padding: 1.35rem;
    display: grid;
    gap: 0.45rem;
  }

  .contact-card__icon {
    margin: 0;
    font-size: 1.5rem;
    line-height: 1;
  }

  .contact-card h3 {
    margin: 0.1rem 0 0;
    font-size: clamp(1.1rem, 1.4vw, 1.28rem);
  }

  .contact-card p,
  .contact-card li {
    line-height: 1.6;
  }

  .contact-card ul {
    margin: 0;
    padding-left: 1.1rem;
    display: grid;
    gap: 0.3rem;
  }

  .contact-card--highlight {
    background:
      radial-gradient(circle at 10% 10%, color-mix(in srgb, var(--accent) 14%, transparent), transparent 50%),
      var(--surface);
  }

  .contact-card a {
    color: var(--accent-2);
    font-weight: 700;
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: border-color var(--transition), color var(--transition);
  }

  .contact-card a:hover {
    color: var(--accent);
    border-color: color-mix(in srgb, var(--accent) 55%, transparent);
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  @media (max-width: 760px) {
    .contact-grid {
      grid-template-columns: 1fr;
    }

    .contact-hero__cta .button {
      width: 100%;
      justify-content: center;
    }
  }
</style>
