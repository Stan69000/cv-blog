---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';

const linkedInUrl = 'https://www.linkedin.com/in/stanislas-bouchet/';
---

<BaseLayout
  title="Contact | Stan Bouchet"
  description="Contacte-moi via LinkedIn pour le moment."
>
  <SiteHeader />

  <main id="main-content" class="container section contact-page">
    <section class="contact-hero section">
      <p class="eyebrow">Contact</p>
      <h1>On se connecte sur LinkedIn.</h1>
      <p class="lead muted">
        Pour le moment, le meilleur canal pour me contacter est LinkedIn.
        Je réponds dès que possible aux messages liés aux projets web, à l’IT terrain,
        à l’accessibilité et aux sujets associatifs.
      </p>
      <p class="contact-hero__cta">
        <a class="button" href={linkedInUrl} target="_blank" rel="noopener noreferrer">
          Écrire sur LinkedIn
        </a>
      </p>
    </section>

    <section class="section contact-grid" aria-label="Informations de contact">
      <article class="contact-card">
        <h2>Pourquoi LinkedIn ?</h2>
        <p>
          C’est aujourd’hui le canal le plus simple pour échanger rapidement et centraliser les demandes.
          Tu peux m’envoyer un message direct avec ton contexte et ton besoin.
        </p>
      </article>

      <article class="contact-card">
        <h2>Pour aller plus vite</h2>
        <ul>
          <li>Présente ton projet en 2-3 lignes.</li>
          <li>Ajoute ton délai ou ta contrainte principale.</li>
          <li>Précise si tu veux un échange ponctuel ou un accompagnement.</li>
        </ul>
      </article>

      <article class="contact-card contact-card--highlight">
        <h2>Profil LinkedIn</h2>
        <p>
          <a href={linkedInUrl} target="_blank" rel="noopener noreferrer">linkedin.com/in/stanislas-bouchet</a>
        </p>
        <p class="muted">Tu peux aussi me suivre pour voir mes actus projets et associatives.</p>
      </article>
    </section>
  </main>

  <SiteFooter />
</BaseLayout>

<style>
  .contact-page {
    padding-top: 1rem;
    padding-bottom: 3rem;
  }

  .contact-hero {
    display: block;
    min-height: auto;
    padding-top: 0;
  }

  .contact-hero h1 {
    width: 100%;
  }

  .contact-hero__cta {
    margin-top: 1.25rem;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }

  .contact-card {
    border: 1px solid var(--line);
    background: var(--surface);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
    padding: 1.15rem;
  }

  .contact-card h2 {
    margin-top: 0;
    margin-bottom: 0.55rem;
    font-size: 1.15rem;
  }

  .contact-card p,
  .contact-card li {
    line-height: 1.6;
  }

  .contact-card ul {
    margin: 0;
    padding-left: 1.1rem;
    display: grid;
    gap: 0.25rem;
  }

  .contact-card--highlight {
    background: linear-gradient(
      170deg,
      color-mix(in srgb, var(--surface-strong) 78%, transparent),
      color-mix(in srgb, var(--surface) 94%, transparent)
    );
  }

  .contact-card a {
    color: var(--accent-2);
    font-weight: 700;
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: border-color var(--transition), color var(--transition);
  }

  .contact-card a:hover {
    color: var(--accent);
    border-color: color-mix(in srgb, var(--accent) 55%, transparent);
  }

  @media (max-width: 980px) {
    .contact-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
