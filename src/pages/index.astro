---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import siteConfig from '../data/site.json';
import homeConfig from '../data/home.json';
import seoConfig from '../data/seo.json';

const pageTitle = seoConfig?.defaultTitle || `${siteConfig.title} | Parcours, projets, engagement et blog`;
const pageDescription = seoConfig?.defaultDescription || siteConfig.description;

const eyebrow = homeConfig.eyebrow || 'Parcours · projets · engagement · blog';
const headline = homeConfig.headline || 'Curieux par nature, touche-à-tout par passion.';
const bio = homeConfig.bio || 'Ce site rassemble plusieurs facettes de mon parcours : mon travail, les projets que je construis, mes engagements associatifs et ce que j\'aime partager par écrit.';
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  ogImage="/images/og/home.jpg"
>
  <SiteHeader />

  <main id="main-content" class="home container">
    <section class="home-intro">
      <p class="eyebrow">{eyebrow}</p>
      <h1 class="home-intro__title">{headline}</h1>
      <p class="lead muted home-intro__lead">
        {bio}
      </p>
    </section>

    {homeConfig.showMap !== false && (
      <section class="home-map-shell">
        <div class="home-map" aria-label="Navigation visuelle principale">
          <img
            src="/images/homepage-cv.png"
            alt=""
            aria-hidden="true"
            width="1415"
            height="848"
          />

          <a class="image-hitbox hitbox-top" href="/parcours" aria-label="Aller à la page Parcours pro">
            <span class="sr-only">Parcours pro</span>
          </a>
          <a class="image-hitbox hitbox-left" href="/projets" aria-label="Aller à la page Projets">
            <span class="sr-only">Projets</span>
          </a>
          <a class="image-hitbox hitbox-right" href="/engagement-associatif" aria-label="Aller à la page Engagement associatif">
            <span class="sr-only">Engagement associatif</span>
          </a>
          <a class="image-hitbox hitbox-bottom" href="/blog" aria-label="Aller à la page Blog">
            <span class="sr-only">Blog</span>
          </a>
        </div>
      </section>
    )}
  </main>

  <SiteFooter />
</BaseLayout>

<style>
  .home {
    padding-top: 1.5rem;
    padding-bottom: 3rem;
  }

  .home-intro {
    margin: 0 auto 2.25rem;
    text-align: center;
  }

  .home-intro__title {
    margin-bottom: 1rem;
    line-height: 1.05;
    text-wrap: balance;
  }

  .home-intro__lead {
    margin: 0 auto;
    text-wrap: pretty;
  }

  .home-map-shell {
    margin-bottom: 2.75rem;
  }

  .home-map {
    position: relative;
    margin: 0 auto;
    overflow: hidden;
    border-radius: var(--radius);
    background: var(--bg);
  }

  .home-map img {
    display: block;
    width: 100%;
    height: auto;
    mix-blend-mode: multiply;
    transform: scale(1.18);
  }

  :root[data-theme='dark'] .home-map img {
    mix-blend-mode: normal;
  }

  .image-hitbox {
    position: absolute;
    display: block;
    border-radius: 20px;
    background: transparent;
    cursor: pointer;
  }

  .image-hitbox:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
    box-shadow: 0 0 0 2px var(--accent);
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .hitbox-top {
    top: 8%;
    left: 39%;
    width: 22%;
    height: 24%;
  }

  .hitbox-left {
    top: 33%;
    left: 12%;
    width: 24%;
    height: 24%;
  }

  .hitbox-right {
    top: 33%;
    right: 12%;
    width: 24%;
    height: 24%;
  }

  .hitbox-bottom {
    bottom: 8%;
    left: 39%;
    width: 22%;
    height: 24%;
  }

  @media (max-width: 900px) {
    .hitbox-top {
      top: 8%;
      left: 37%;
      width: 26%;
      height: 24%;
    }

    .hitbox-left {
      top: 33%;
      left: 9%;
      width: 28%;
      height: 24%;
    }

    .hitbox-right {
      top: 33%;
      right: 9%;
      width: 28%;
      height: 24%;
    }

    .hitbox-bottom {
      bottom: 8%;
      left: 37%;
      width: 26%;
      height: 24%;
    }
  }

  @media (max-width: 640px) {
    .home {
      padding-top: 1rem;
    }

    .home-intro {
      margin-bottom: 1.5rem;
    }
  }
</style>
