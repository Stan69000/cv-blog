---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import CompassRose from '../components/CompassRose.astro';
import siteConfig from '../data/site.json';
import homeConfig from '../data/home.json';
import seoConfig from '../data/seo.json';

const pageTitle = seoConfig?.defaultTitle || `${siteConfig.title} | Parcours, projets, engagement et blog`;
const pageDescription = seoConfig?.defaultDescription || siteConfig.description;

const eyebrow = homeConfig.eyebrow || 'Parcours · projets · engagement · blog';
const headline = homeConfig.headline || 'Curieux par nature, touche-à-tout par passion.';
const bio = homeConfig.bio || 'Ce site rassemble plusieurs facettes de mon parcours : mon travail, les projets que je construis, mes engagements associatifs et ce que j\'aime partager par écrit.';
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  ogImage="/images/og/home.jpg"
>
  <SiteHeader />

  <main id="main-content" class="home container">
    <section class="home-intro">
      <p class="eyebrow">{eyebrow}</p>
      <h1 class="home-intro__title">{headline}</h1>
      <p class="lead muted home-intro__lead">
        {bio}
      </p>
    </section>

    {homeConfig.showMap !== false && (
      <section class="home-compass-shell">
        <nav class="compass-nav" aria-label="Navigation par rose des vents">

          <a href="/engagement-associatif" class="compass-label compass-label--n">
            <span class="compass-label__main">Engagement</span>
            <span class="compass-label__sub">associatif</span>
          </a>

          <a href="/blog" class="compass-label compass-label--o">
            <span class="compass-label__main">Blog</span>
          </a>

          <div class="compass-rose-wrapper">
            <CompassRose size={300} ariaLabel="Rose des vents — navigation du site" />
          </div>

          <a href="/parcours" class="compass-label compass-label--e">
            <span class="compass-label__main">Parcours</span>
            <span class="compass-label__sub">professionnel</span>
          </a>

          <a href="/projets" class="compass-label compass-label--s">
            <span class="compass-label__main">Projets</span>
          </a>

        </nav>
      </section>
    )}
  </main>

  <SiteFooter />
</BaseLayout>

<style>
  .home {
    padding-top: 1.5rem;
    padding-bottom: 3rem;
  }

  .home-intro {
    margin: 0 auto 2.25rem;
    text-align: center;
  }

  .home-intro__title {
    margin-bottom: 1rem;
    line-height: 1.05;
    text-wrap: balance;
  }

  .home-intro__lead {
    margin: 0 auto;
    text-wrap: pretty;
  }

  /* ── Compass navigation ─────────────────────────────── */

  .home-compass-shell {
    margin-bottom: 2.75rem;
    overflow: hidden; /* évite le scroll horizontal sur mobile */
  }

  /* Mapping des tokens du site vers ceux du composant */
  .compass-rose-wrapper {
    --color-bg: var(--bg);
    --color-bg-2: var(--surface);
    --color-ink: var(--text);
    --color-accent: var(--accent);
    grid-area: rose;
  }

  /* Mobile-first : grille 2 colonnes, rose pleine largeur */
  .compass-nav {
    display: grid;
    grid-template-areas:
      "n    n"
      "rose rose"
      "s    s"
      "o    e";
    grid-template-columns: 1fr 1fr;
    gap: 1rem 0.5rem;
    align-items: center;
    justify-items: center;
    max-width: 680px;
    margin: 0 auto;
  }

  /* Desktop : disposition en croix */
  @media (min-width: 640px) {
    .compass-nav {
      grid-template-areas:
        ".  n  ."
        "o rose e"
        ".  s  .";
      grid-template-columns: 1fr auto 1fr;
      grid-template-rows: auto auto auto;
      gap: 1.75rem 2.5rem;
    }
  }

  /* Labels directionnels */
  .compass-label {
    display: flex;
    flex-direction: column;
    gap: 0.12rem;
    text-decoration: none;
    transition: opacity var(--transition), transform var(--transition);
  }

  .compass-label:hover {
    opacity: 0.6;
    transform: scale(1.04);
  }

  .compass-label--n {
    grid-area: n;
    text-align: center;
    align-items: center;
  }

  .compass-label--s {
    grid-area: s;
    text-align: center;
    align-items: center;
  }

  .compass-label--e {
    grid-area: e;
    text-align: left;
    align-items: flex-start;
    justify-self: start;
  }

  .compass-label--o {
    grid-area: o;
    text-align: right;
    align-items: flex-end;
    justify-self: end;
  }

  .compass-label__main {
    font-family: var(--font-heading);
    font-size: clamp(1rem, 2.5vw, 1.4rem);
    font-weight: 700;
    font-style: italic;
    color: var(--text);
    line-height: 1.1;
  }

  .compass-label__sub {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    color: var(--muted);
    font-weight: 500;
    font-style: normal;
  }

  @media (max-width: 640px) {
    .home {
      padding-top: 1rem;
    }

    .home-intro {
      margin-bottom: 1.5rem;
    }

    .compass-label__main {
      font-size: 0.95rem;
    }

    .compass-label--o {
      padding-right: 0.5rem;
    }

    .compass-label--e {
      padding-left: 0.5rem;
    }
  }
</style>
