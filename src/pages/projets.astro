---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';

const featuredProjects = [
  {
    type: 'Site web',
    name: 'Le Singe du Numérique',
    date: 'Avril 2026',
    url: 'https://lesingedunumerique.fr/',
    lines: [
      'Conception d’un site orienté lecture et clarté éditoriale.',
      'Structuration du contenu pour garder une navigation simple.',
      'Travail sur la cohérence visuelle et le rythme des pages.',
      'Objectif : rendre le message lisible et immédiatement utile.'
    ]
  },
  {
    type: 'Refonte web',
    name: 'Natura au Féminin',
    date: 'Refonte d’un site existant',
    url: 'https://naturaufeminin.fr/',
    lines: [
      'Refonte complète d’un site déjà en production.',
      'Reprise de la structure pour améliorer la compréhension.',
      'Allègement de l’interface pour fluidifier le parcours.',
      'Objectif : garder l’identité du site, avec plus de clarté.'
    ]
  },
  {
    type: 'Site personnel',
    name: 'stan-bouchet.eu',
    date: 'Avril 2026',
    url: 'https://stan-bouchet.eu/',
    lines: [
      'Création d’un site personnel orienté présentation claire.',
      'Mise en avant des sujets techniques et du parcours.',
      'Travail de hiérarchisation pour limiter le bruit visuel.',
      'Objectif : un site simple, lisible et facile à maintenir.'
    ]
  },
  {
    type: 'Projet personnel',
    name: 'stan-bouchet.com',
    date: 'Avril 2026',
    url: 'https://stan-bouchet.com/',
    lines: [
      'Site principal construit comme hub de navigation.',
      'Pages organisées en univers : parcours, projets, engagement, blog.',
      'Accent mis sur la lisibilité, la structure et la cohérence globale.',
      'Objectif : un espace vivant pour présenter le travail dans la durée.'
    ]
  },
  {
    type: 'Open source',
    name: 'RGAA Audit',
    date: 'Avril 2026',
    url: 'https://stan69000.github.io/rgaa-audit/',
    lines: [
      'Publication d’un outil orienté audit d’accessibilité RGAA.',
      'Approche pragmatique pour faciliter les vérifications.',
      'Interface pensée pour un usage concret sur le terrain.',
      'Objectif : aider à améliorer l’accessibilité dès les premières itérations.'
    ]
  },
  {
    type: 'Association',
    name: 'Mise en place Google Workspace (RVAz)',
    date: '2025',
    url: null,
    lines: [
      'Déploiement de Google Workspace pour l’association RVAz.',
      'Organisation des comptes, droits et espaces partagés.',
      'Structuration des usages pour faciliter le travail collectif.',
      'Objectif : rendre le fonctionnement quotidien plus fluide et fiable.'
    ]
  }
];

---

<BaseLayout
  title="Projets | Stan Bouchet"
  description="Une sélection de projets personnels, internes, open source et web autour de l’automatisation, de la clarté et de l’utilité."
>
  <SiteHeader />

  <main id="main-content" class="container section universe universe--projects">
    <section class="hero section">
      <p class="eyebrow">Projets</p>
      <h1>Construire des choses utiles, dans différents contextes.</h1>
      <p class="lead muted">
        Cette page rassemble des projets personnels, web, open source ou en cours d’exploration.
        Ils sont différents dans leur forme, mais ont souvent le même point de départ : une envie de rendre quelque chose plus clair, plus simple, plus utile ou mieux pensé.
        Je les mène avec sérieux, curiosité et exigence, même en dehors du cadre professionnel.
        Avec une différence importante : ici, j’ai plus de liberté pour tester, ajuster, recommencer et faire évoluer les choses dans le temps.
      </p>
    </section>

    <section class="section" aria-labelledby="featured-title">
      <h2 id="featured-title">Mes projets</h2>
      <div class="project-grid">
        {featuredProjects.map((project) => (
          <article class="project-card">
            <p class="project-type">{project.type}</p>
            <h3>{project.name}</h3>
            <p class="project-date">{project.date}</p>
            <ul class="project-lines" aria-label={`Description du projet ${project.name}`}>
              {project.lines.map((line) => (
                <li>{line}</li>
              ))}
            </ul>
            {project.url && (
              <p class="project-link-wrap">
                <a href={project.url} target="_blank" rel="noopener noreferrer" class="project-link">
                  Voir le projet
                </a>
              </p>
            )}
          </article>
        ))}
      </div>
    </section>

  </main>

  <SiteFooter />
</BaseLayout>

<style>
  .hero {
    display: block;
    min-height: auto;
    grid-template-columns: 1fr;
    padding-top: 1rem;
  }

  .hero h1 {
    width: 100%;
  }

  .project-grid {
    display: grid;
    gap: 1rem;
  }

  .project-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .project-card {
    border: 1px solid var(--line);
    background: var(--surface);
    box-shadow: var(--shadow);
    border-radius: var(--radius);
    padding: 1.25rem;
    transition: transform var(--transition), border-color var(--transition), box-shadow var(--transition);
  }

  .project-card:hover {
    transform: translateY(-2px);
    border-color: var(--accent);
    box-shadow: var(--shadow);
  }

  .project-card h3 {
    margin-top: 0;
    margin-bottom: 0.5rem;
  }

  .project-type {
    margin: 0 0 0.65rem;
    color: var(--muted);
    font-size: 0.8125rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .project-date {
    margin: 0.2rem 0 0.8rem;
    color: var(--muted);
    font-size: 0.9rem;
    font-weight: 600;
  }

  .project-lines {
    margin: 0;
    padding-left: 1.1rem;
    display: grid;
    gap: 0.45rem;
  }

  .project-lines li {
    line-height: 1.5;
  }

  .project-link-wrap {
    margin-top: 1rem;
  }

  .project-link {
    display: inline-flex;
    align-items: center;
    font-weight: 600;
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: border-color var(--transition), color var(--transition);
  }

  .project-link:hover {
    border-color: currentColor;
  }

  @media (max-width: 900px) {
    .project-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .project-card {
      padding: 1rem;
    }

    .project-lines {
      gap: 0.38rem;
    }
  }
</style>
