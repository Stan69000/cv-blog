---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import { featuredProjectsOrdered, formatProjectDate, getProjectScreenshot } from '../data/projects';

const typeIcons: Record<string, string> = {
  'App macOS': '🖥',
  'Création web': '🌐',
  'Refonte web': '✏️',
  'Open source': '⚡',
  'Déploiement IT': '🗂️'
};
---

<BaseLayout
  title="Projets | Stan Bouchet"
  description="J’aime construire des outils, contenus et expériences qui réduisent la friction et rendent le numérique plus clair, plus fluide et plus accessible."
  ogImage="/images/og/projets.jpg"
>
  <SiteHeader />

  <main id="main-content" class="container section universe universe--projects">
    <section class="hero section">
      <div class="hero-panel">
        <p class="eyebrow">Projets</p>
        <h1>Construire des choses utiles, dans différents contextes.</h1>
        <p class="lead muted">
          J’aime construire des outils, contenus et expériences qui réduisent la friction et rendent le numérique plus clair, plus fluide et plus accessible.
        </p>
      </div>
    </section>

    <section class="section" aria-labelledby="featured-title">
      <div class="projects-header">
        <h2 id="featured-title">Mes projets</h2>
        <nav class="filter-bar" aria-label="Filtrer les projets">
          <button class="filter-btn is-active" data-filter="all" type="button">Tous</button>
          <button class="filter-btn" data-filter="App macOS" type="button">App macOS</button>
          <button class="filter-btn" data-filter="Création web" type="button">Création web</button>
          <button class="filter-btn" data-filter="Refonte web" type="button">Refonte web</button>
          <button class="filter-btn" data-filter="Open source" type="button">Open source</button>
          <button class="filter-btn" data-filter="Déploiement IT" type="button">Déploiement IT</button>
        </nav>
      </div>
      <p class="filter-count" aria-live="polite" aria-atomic="true"></p>
      <div class="project-grid" id="project-grid">
        {featuredProjectsOrdered.map((project) => {
          const screenshot = getProjectScreenshot(project);
          return (
          <article
            class="project-card"
            data-type={project.type}
          >
            {project.url ? (
              <a href={project.url} target="_blank" rel="noopener noreferrer" class="project-thumb" tabindex="-1" aria-hidden="true">
                {screenshot ? (
                  <img src={screenshot} alt="" loading="lazy" decoding="async" />
                ) : (
                  <span class="project-thumb__placeholder">
                    <span class="placeholder-icon" aria-hidden="true">{typeIcons[project.type] ?? '📁'}</span>
                    <span class="placeholder-label">{project.type}</span>
                  </span>
                )}
              </a>
            ) : (
              <div class="project-thumb" aria-hidden="true">
                {screenshot ? (
                  <img src={screenshot} alt="" loading="lazy" decoding="async" />
                ) : (
                  <span class="project-thumb__placeholder">
                    <span class="placeholder-icon" aria-hidden="true">{typeIcons[project.type] ?? '📁'}</span>
                    <span class="placeholder-label">{project.type}</span>
                  </span>
                )}
              </div>
            )}
            <header class="project-head">
              <p class="project-type">{project.type}</p>
              <time class="project-date" datetime={project.startedAt}>{formatProjectDate(project)}</time>
            </header>

            <h3>
              {project.url ? (
                <a href={project.url} target="_blank" rel="noopener noreferrer" class="project-title-link">
                  {project.name}
                </a>
              ) : (
                project.name
              )}
            </h3>
            <p class="project-context">{project.context}</p>

            <div class="project-block">
              <p class="project-block-title">Technique</p>
              <ul class="project-list" aria-label={`Technique utilisée pour ${project.name}`}>
                {project.technique.map((line) => (
                  <li>{line}</li>
                ))}
              </ul>
            </div>

            <div class="project-block">
              <p class="project-block-title">Impact</p>
              <ul class="project-list" aria-label={`Impact du projet ${project.name}`}>
                {project.impact.map((line) => (
                  <li>{line}</li>
                ))}
              </ul>
            </div>

            <ul class="project-tags" aria-label={`Technologies et mots-clés pour ${project.name}`}>
              {project.tags.map((tag) => (
                <li>{tag}</li>
              ))}
            </ul>

            {(project.url || project.extensionUrl) && (
              <p class="project-link-wrap">
                {project.url && (
                  <a href={project.url} target="_blank" rel="noopener noreferrer" class="project-link">
                    Voir le projet
                  </a>
                )}
                {project.extensionUrl && (
                  <a href={project.extensionUrl} target="_blank" rel="noopener noreferrer" class="project-link">
                    Voir l’extension
                  </a>
                )}
              </p>
            )}
          </article>
        );
        })}
      </div>
    </section>
  </main>

  <SiteFooter />
</BaseLayout>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
  const cards = document.querySelectorAll<HTMLElement>('.project-card');
  const countEl = document.querySelector<HTMLElement>('.filter-count');

  function updateCount(visible: number, total: number) {
    if (!countEl) return;
    countEl.textContent = visible === total ? '' : `${visible} projet${visible > 1 ? 's' : ''} affiché${visible > 1 ? 's' : ''}`;
  }

  function applyFilter(filter: string) {
    let visible = 0;
    cards.forEach((card) => {
      const match =
        filter === 'all' ||
        card.dataset.type === filter;

      card.hidden = !match;
      if (match) visible++;
    });
    updateCount(visible, cards.length);
  }

  buttons.forEach((btn) => {
    btn.addEventListener('click', () => {
      buttons.forEach((b) => {
        b.classList.remove('is-active');
        b.removeAttribute('aria-current');
      });
      btn.classList.add('is-active');
      btn.setAttribute('aria-current', 'true');
      applyFilter(btn.dataset.filter ?? 'all');
    });
  });

  updateCount(cards.length, cards.length);
</script>

<style>
  .hero {
    display: block;
    min-height: auto;
    grid-template-columns: 1fr;
    padding-top: 1rem;
  }

  .hero h1 {
    width: 100%;
  }

  .projects-header {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.75rem 1.5rem;
    margin-bottom: 1.1rem;
  }

  .projects-header h2 {
    margin: 0;
  }

  .filter-bar {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .filter-btn {
    border: 1px solid var(--line);
    background: var(--surface);
    color: var(--muted);
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: 500;
    border-radius: 999px;
    padding: 0.45rem 0.9rem;
    cursor: pointer;
    transition: color var(--transition), background var(--transition), border-color var(--transition);
    white-space: nowrap;
  }

  .filter-btn:hover {
    color: var(--text);
    border-color: color-mix(in srgb, var(--accent) 55%, transparent);
  }

  .filter-btn.is-active {
    color: var(--accent-contrast);
    background: var(--accent);
    border-color: var(--accent);
  }

  .filter-count {
    margin: -0.4rem 0 0.85rem;
    color: var(--muted);
    font-size: var(--text-xs);
    min-height: 1.4em;
  }

  .project-card[hidden] {
    display: none;
  }

  .project-grid {
    display: grid;
    gap: 1rem;
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .project-card {
    position: relative;
    overflow: hidden;
    border: 1px solid var(--line);
    background:
      linear-gradient(
        160deg,
        color-mix(in srgb, var(--surface-strong) 68%, transparent) 0%,
        color-mix(in srgb, var(--surface) 95%, transparent) 56%,
        color-mix(in srgb, var(--surface) 88%, transparent) 100%
      );
    box-shadow: var(--shadow);
    border-radius: var(--radius);
    padding: 1.25rem;
    display: grid;
    gap: 1rem;
    transition: transform var(--transition), border-color var(--transition), box-shadow var(--transition), background var(--transition);
  }

  .project-thumb {
    position: relative;
    aspect-ratio: 16 / 9;
    border-radius: calc(var(--radius) - 0.25rem);
    overflow: hidden;
    border: 1px solid color-mix(in srgb, var(--line) 70%, transparent);
    background:
      linear-gradient(135deg, color-mix(in srgb, var(--accent) 22%, var(--surface)), color-mix(in srgb, var(--accent-2) 18%, var(--surface)));
    margin: -0.25rem -0.25rem 0;
  }

  .project-thumb img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center;
    transition: transform var(--transition);
  }

  a.project-thumb {
    display: block;
    cursor: pointer;
  }

  a.project-thumb:hover img {
    transform: scale(1.04);
  }

  .project-card:hover .project-thumb img {
    transform: scale(1.02);
  }

  .project-thumb__placeholder {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.55rem;
  }

  .placeholder-icon {
    font-size: clamp(2rem, 5vw, 2.75rem);
    line-height: 1;
  }

  .placeholder-label {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: color-mix(in srgb, var(--text) 45%, transparent);
    font-weight: 600;
  }

  .project-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 3px;
    background: linear-gradient(90deg, var(--accent), color-mix(in srgb, var(--accent-2) 75%, transparent));
    opacity: 0.66;
    pointer-events: none;
  }

  .project-card:hover {
    transform: translateY(-3px);
    border-color: color-mix(in srgb, var(--accent) 66%, transparent);
    box-shadow: 0 18px 34px color-mix(in srgb, var(--accent) 11%, transparent);
  }

  .project-head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .project-card h3 {
    margin: 0;
    line-height: 1.2;
  }

  .project-title-link {
    color: inherit;
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: border-color var(--transition), color var(--transition);
  }

  .project-title-link:hover {
    color: var(--accent);
    border-color: color-mix(in srgb, var(--accent) 55%, transparent);
  }

  .project-type {
    margin: 0;
    width: fit-content;
    border: 1px solid var(--line);
    border-radius: 999px;
    padding: 0.28rem 0.62rem;
    color: var(--muted);
    font-size: var(--text-xs);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    background: var(--surface);
  }

  .project-date {
    margin: 0;
    color: var(--muted);
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.02em;
    border: 1px dashed color-mix(in srgb, var(--line) 80%, transparent);
    border-radius: 999px;
    padding: 0.24rem 0.55rem;
    background: color-mix(in srgb, var(--surface) 86%, transparent);
  }

  .project-context {
    margin: 0;
    line-height: 1.6;
  }

  .project-block {
    display: grid;
    gap: 0.4rem;
    border-top: 1px solid color-mix(in srgb, var(--line) 70%, transparent);
    padding-top: 0.75rem;
  }

  .project-block-title {
    margin: 0;
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--muted);
    font-weight: 700;
  }

  .project-list {
    margin: 0;
    padding-left: 1.1rem;
    display: grid;
    gap: 0.34rem;
  }

  .project-list li {
    line-height: 1.5;
  }

  .project-tags {
    margin: 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
  }

  .project-tags li {
    border: 1px solid var(--line);
    border-radius: 0.85rem;
    padding: 0.33rem 0.72rem;
    font-size: var(--text-xs);
    color: var(--muted);
    background: color-mix(in srgb, var(--surface) 94%, transparent);
    transition: border-color var(--transition), color var(--transition), transform var(--transition);
  }

  .project-tags li:hover {
    border-color: color-mix(in srgb, var(--accent) 55%, transparent);
    color: var(--text);
    transform: translateY(-1px);
  }

  .project-link-wrap {
    margin: 0.15rem 0 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .project-link {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-weight: 600;
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: border-color var(--transition), color var(--transition);
  }

  .project-link::after {
    content: '↗';
    font-size: 0.9em;
  }

  .project-link:hover {
    border-color: currentColor;
  }

  @media (max-width: 900px) {
    .project-grid {
      grid-template-columns: 1fr;
    }

    .projects-header {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.65rem;
    }
  }

  @media (max-width: 640px) {
    .project-card {
      padding: 1rem;
      gap: 0.8rem;
    }

    .project-head {
      align-items: flex-start;
    }
  }
</style>
