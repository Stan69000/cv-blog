---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import engagementData from '../data/engagement.json';

const { stats, timeline, spotlightEyebrow, spotlightTitle, spotlightIntro, spotlightUrl, spotlightCta, workEyebrow, workTitle, workParagraphs } = engagementData;
---

<BaseLayout
  title="Engagement associatif | Stan Bouchet"
  description="Une partie de mes projets cherchent à rendre le numérique plus simple, plus compréhensible et plus humain au quotidien."
  ogImage="/images/og/engagement.jpg"
>
  <SiteHeader />

  <main id="main-content" class="container section universe universe--association">
    <section class="hero section">
      <div class="hero-panel">
        <p class="eyebrow">Engagement associatif</p>
        <h1>Un fil rouge : être utile, transmettre et construire avec les autres.</h1>
        <p class="lead muted">
          Une partie de mes projets cherchent à rendre le numérique plus simple, plus compréhensible et plus humain au quotidien.
        </p>
      </div>
    </section>

    <div class="stats-bar" aria-label="Chiffres clés">
      {stats.map((stat) => (
        <div class="stats-bar__item">
          <span class="stats-bar__value">{stat.value}</span>
          <span class="stats-bar__label">{stat.label}</span>
        </div>
      ))}
    </div>

    <section class="section" aria-labelledby="timeline-title">
      <div class="section-head">
        <p class="eyebrow">Parcours</p>
        <h2 id="timeline-title">Un parcours dans le temps</h2>
      </div>

      <ol class="timeline">
        {timeline.map((item) => (
          <li class="timeline__item" data-active={item.active ? 'true' : undefined}>
            <div class="timeline__item-head">
              <p class="meta">{item.period}</p>
              {item.active && <span class="timeline__badge">Actif</span>}
            </div>
            <h3>{item.title}</h3>
            <p>{item.text}</p>
            {item.details && item.details.length > 0 && (
              <ul class="timeline__details" aria-label={`Détails de ${item.title}`}>
                {item.details.map((detail) => (
                  <li>{detail}</li>
                ))}
              </ul>
            )}
          </li>
        ))}
      </ol>
    </section>

    <section class="section spotlight" aria-labelledby="spotlight-title">
      <div class="spotlight__top">
        <p class="eyebrow">{spotlightEyebrow}</p>
        <h2 id="spotlight-title">{spotlightTitle}</h2>
      </div>

      <div class="spotlight__body">
        <p class="spotlight__mission">{spotlightIntro}</p>
        {spotlightUrl && (
          <p class="spotlight__link-wrap">
            <a href={spotlightUrl} target="_blank" rel="noopener noreferrer" class="spotlight__cta">
              {spotlightCta}
            </a>
          </p>
        )}
      </div>
    </section>

    <section class="section" aria-labelledby="work-link-title">
      <div class="section-head">
        <p class="eyebrow">{workEyebrow}</p>
        <h2 id="work-link-title">{workTitle}</h2>
      </div>

      <div class="work-link">
        {workParagraphs.map((para, i) => (
          i === workParagraphs.length - 1
            ? <p class="work-link__conclusion">{para}</p>
            : <p>{para}</p>
        ))}
      </div>
    </section>
  </main>

  <SiteFooter />
</BaseLayout>

<style>
  .hero {
    display: block;
    min-height: auto;
    grid-template-columns: 1fr;
    padding-top: 1rem;
  }

  .hero h1 {
    width: 100%;
  }

  .stats-bar {
    margin: 2rem 0 2.5rem;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.9rem;
  }

  .stats-bar__item {
    border: 1px solid var(--line);
    background: var(--surface);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
    padding: 1rem 1.2rem;
    display: grid;
    gap: 0.25rem;
  }

  .stats-bar__value {
    font-family: var(--font-heading);
    font-size: clamp(1.75rem, 3vw, 2.2rem);
    font-weight: 600;
    line-height: 1;
    color: var(--accent);
  }

  .stats-bar__label {
    color: var(--muted);
    font-size: var(--text-sm);
    line-height: 1.4;
  }

  .section-head {
    margin-bottom: 1rem;
    display: grid;
    gap: 0.3rem;
    justify-content: flex-start;
    align-items: flex-start;
  }

  .section-head h2 {
    margin: 0;
    text-align: left;
  }

  .timeline {
    position: relative;
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.9rem;
  }

  .timeline::before {
    content: '';
    position: absolute;
    left: 0.38rem;
    top: 0.35rem;
    bottom: 0.35rem;
    width: 2px;
    background: color-mix(in srgb, var(--accent) 55%, transparent);
    opacity: 0.7;
  }

  .timeline__item {
    position: relative;
    margin-left: 1.4rem;
    padding: 1rem 1rem 1rem 1.1rem;
    border: 1px solid var(--line);
    background: var(--surface);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
  }

  .timeline__item[data-active] {
    border-color: color-mix(in srgb, var(--accent) 40%, var(--line));
    background: color-mix(in srgb, var(--accent) 4%, var(--surface));
  }

  .timeline__item::before {
    content: '';
    position: absolute;
    left: -1.12rem;
    top: 1.15rem;
    width: 0.62rem;
    height: 0.62rem;
    border-radius: 999px;
    background: var(--accent);
    box-shadow: 0 0 0 4px color-mix(in srgb, var(--accent) 20%, transparent);
  }

  .timeline__item[data-active]::before {
    box-shadow: 0 0 0 4px color-mix(in srgb, var(--accent) 30%, transparent),
      0 0 8px color-mix(in srgb, var(--accent) 40%, transparent);
  }

  .timeline__item-head {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    flex-wrap: wrap;
    margin-bottom: 0;
  }

  .timeline__item-head .meta {
    margin-bottom: 0;
  }

  .timeline__badge {
    display: inline-block;
    font-size: 0.68rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--accent-contrast);
    background: var(--accent);
    border-radius: 999px;
    padding: 0.18rem 0.52rem;
    line-height: 1.4;
  }

  .timeline__item h3 {
    margin: 0.35rem 0 0.35rem;
  }

  .timeline__details {
    margin: 0.45rem 0 0;
    padding-left: 1.1rem;
    display: grid;
    gap: 0.3rem;
  }

  .timeline__details li {
    line-height: 1.45;
  }

  .meta {
    color: var(--muted);
    font-size: var(--text-xs);
    font-weight: 600;
    margin-bottom: 0.4rem;
  }

  .spotlight {
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: linear-gradient(180deg, color-mix(in srgb, var(--surface) 90%, transparent), var(--surface));
    box-shadow: var(--shadow);
    padding: 1.2rem;
  }

  .spotlight__top {
    margin-bottom: 0.75rem;
    display: grid;
    gap: 0.3rem;
    justify-items: start;
  }

  .spotlight__top h2 {
    margin: 0;
    text-align: left;
  }

  .spotlight__body {
    display: grid;
    gap: 1rem;
  }

  .spotlight__mission {
    margin: 0;
    font-family: var(--font-sans);
    font-size: 1.05rem;
    line-height: 1.7;
    color: var(--text);
  }

  .spotlight__link-wrap {
    margin: 0;
  }

  .spotlight__cta {
    display: inline-flex;
    align-items: center;
    font-weight: 600;
    color: var(--accent);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: border-color var(--transition);
  }

  .spotlight__cta:hover {
    border-color: currentColor;
  }


  .work-link {
    border: 1px solid var(--line);
    background: var(--surface);
    box-shadow: var(--shadow);
    border-radius: var(--radius);
    padding: 1.2rem;
    display: grid;
    gap: 0.85rem;
  }

  .work-link__conclusion {
    margin-top: 0.2rem;
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 1rem;
    color: var(--text);
  }

  @media (max-width: 900px) {
    .learning-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .stats-bar {
      grid-template-columns: 1fr;
      gap: 0.6rem;
      margin-bottom: 1.25rem;
    }

    .timeline__item,
    .spotlight,
    .learning-grid li,
    .work-link {
      padding: 0.95rem;
    }

    .timeline__item {
      margin-left: 1.15rem;
    }

    .timeline__item::before {
      left: -0.95rem;
    }
  }
</style>
