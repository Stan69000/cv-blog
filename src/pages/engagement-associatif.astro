---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';

const timeline = [
  {
    period: '2000 → 2005',
    title: 'Sapeur-pompier volontaire SDIS du Rhône',
    text: 'Première expérience forte d’engagement. Intervenir, aider, gérer l’urgence et travailler en équipe.'
  },
  {
    period: '2007 → 2009',
    title: 'Équipier secouriste – Croix-Rouge Délégation Locale de Lyon',
    text: 'Poste de secours, plan d’urgence, initiation aux premiers secours grand public et pédiatrique, chauffeur VL.'
  },
  {
    period: '2010 → 2014',
    title: 'Président – Espace Animation Pause Jeux pour les 0 à 6 ans',
    text: 'Gestion d’une structure associative, animation et encadrement d’équipe.',
    details: [
      'Refonte du site web.',
      'Création de l’image de marque.',
      'Employeur bénévole d’une salariée.',
      'Suivi administratif avec la mairie de St Priest et la CAF du Rhône.',
      'Mise en place du prêt de jeux.',
      'Mise en place de la prestation de service.'
    ]
  },
  {
    period: '2014',
    title: 'Animateur / conception – Biennale d’art contemporain de Lyon',
    text: 'Création de contenu pédagogique pour enfants dans un contexte culturel.'
  },
  {
    period: '2020 → 2021',
    title: 'Président fondateur – association Au Chouette Bar - Fleurieux sur l’Arbresle',
    text: 'Création d’un bar associatif avec une salariée.',
    details: [
      'Formation permis d’exploitation Licence IV.',
      'Service à table.',
      'Gestion de la caisse.',
      'Gestion des conflits.',
      'Création de l’image de marque : site web, logo, polo, menu, flyers.'
    ]
  },
  {
    period: '2021 → 2022',
    title: 'Conseiller municipal - Fleurieux sur l’Arbresle',
    text: 'Engagement local avec travail en commission (sécurité, communication, médiathèque).'
  },
  {
    period: '2022 → 2023',
    title: 'Trésorier adjoint – Sou des écoles - Fleurieux sur l’Arbresle',
    text: 'Gestion financière et participation à la vie associative locale.'
  },
  {
    period: '2023 → aujourd’hui',
    title: 'Trésorier adjoint – Radio / Web TV - RVAz',
    text: 'Évolution d’une radio vers une Web TV, structuration et participation active.',
    details: ['Photographe.', 'Monteur vidéo.', 'Cadreur.', 'Webmaster (projet de refonte du site web).']
  },
  {
    period: '2025 → aujourd’hui',
    title: 'Parrain – EDEN School - Villeurbanne',
    text: 'Accompagnement d’un jeune développeur, transmission et mentorat.'
  }
];

const learnings = [
  'Travailler en équipe dans des contextes variés',
  'Gérer des responsabilités concrètes',
  'Expliquer simplement des sujets parfois complexes',
  'S’adapter à des publics très différents',
  'Construire des projets sur la durée'
];
---

<BaseLayout
  title="Engagement associatif | Stan Bouchet"
  description="Un parcours d’engagement associatif sur le long terme, entre aide, transmission et collectif."
>
  <SiteHeader />

  <main id="main-content" class="container section universe universe--association">
    <section class="hero section">
      <div class="hero-panel">
        <p class="eyebrow">Engagement associatif</p>
        <h1>Un fil rouge : être utile, transmettre et construire avec les autres.</h1>
        <p class="lead muted">
          Mon engagement associatif ne s’est pas construit d’un coup. Il s’inscrit dans le temps,
          à travers différentes expériences, contextes et rôles.
          Ce qui ne change pas, c’est l’envie d’aider, de partager et de participer à des projets collectifs.
        </p>
      </div>
    </section>

    <section class="section" aria-labelledby="timeline-title">
      <div class="section-head">
        <p class="eyebrow">Parcours</p>
        <h2 id="timeline-title">Un parcours dans le temps</h2>
      </div>

      <ol class="timeline">
        {timeline.map((item) => (
          <li class="timeline__item">
            <p class="meta">{item.period}</p>
            <h3>{item.title}</h3>
            <p>{item.text}</p>
            {item.details && (
              <ul class="timeline__details" aria-label={`Détails de ${item.title}`}>
                {item.details.map((detail) => (
                  <li>{detail}</li>
                ))}
              </ul>
            )}
          </li>
        ))}
      </ol>
    </section>

    <section class="section spotlight" aria-labelledby="spotlight-title">
      <div class="spotlight__top">
        <p class="eyebrow">Focus actuel</p>
        <h2 id="spotlight-title">Aujourd’hui : Le Singe du Numérique</h2>
      </div>

      <p class="spotlight__intro">
        Une association qui s’inscrit naturellement dans la continuité de mon parcours.
      </p>

      <div class="spotlight__grid">
        <article class="spotlight__card">
          <h3>Rendre le numérique plus accessible</h3>
          <p>
            Avec Le Singe du Numérique, l’idée est de rendre les sujets numériques plus accessibles :
            cybersécurité, outils, usages… avec une approche simple et concrète.
          </p>
        </article>

        <article class="spotlight__card">
          <h3>Relier métier et engagement</h3>
          <p>
            C’est une manière de faire le lien entre mon métier et mon engagement :
            expliquer, transmettre et rendre les choses utiles pour les autres.
          </p>
        </article>
      </div>
    </section>

    <section class="section" aria-labelledby="learning-title">
      <div class="section-head">
        <p class="eyebrow">Apprentissages</p>
        <h2 id="learning-title">Ce que ces expériences m’ont appris</h2>
      </div>

      <ul class="learning-grid">
        {learnings.map((item) => (
          <li>{item}</li>
        ))}
      </ul>
    </section>

    <section class="section" aria-labelledby="work-link-title">
      <div class="section-head">
        <p class="eyebrow">Impact métier</p>
        <h2 id="work-link-title">Le lien avec mon travail</h2>
      </div>

      <div class="work-link">
        <p>
          Cet engagement influence directement ma manière de travailler. La pédagogie, l’écoute,
          la clarté et le sens du collectif sont au cœur de mon quotidien IT.
        </p>
        <p>
          Que ce soit dans le support, la cybersécurité ou la documentation, je retrouve les mêmes logiques :
          rendre les choses compréhensibles et utiles.
        </p>
        <p class="work-link__conclusion">
          Ces expériences ne sont pas à côté de mon parcours professionnel. Elles en font partie.
        </p>
      </div>
    </section>
  </main>

  <SiteFooter />
</BaseLayout>

<style>
  .hero {
    display: block;
    min-height: auto;
    grid-template-columns: 1fr;
    padding-top: 1rem;
  }

  .hero h1 {
    width: 100%;
  }

  .section-head {
    margin-bottom: 1rem;
    display: grid;
    gap: 0.3rem;
    justify-content: flex-start;
    align-items: flex-start;
  }

  .section-head h2 {
    margin: 0;
    text-align: left;
  }

  .timeline {
    position: relative;
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.9rem;
  }

  .timeline::before {
    content: '';
    position: absolute;
    left: 0.38rem;
    top: 0.35rem;
    bottom: 0.35rem;
    width: 2px;
    background: color-mix(in srgb, var(--accent) 55%, transparent);
    opacity: 0.7;
  }

  .timeline__item {
    position: relative;
    margin-left: 1.4rem;
    padding: 1rem 1rem 1rem 1.1rem;
    border: 1px solid var(--line);
    background: var(--surface);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
  }

  .timeline__item::before {
    content: '';
    position: absolute;
    left: -1.12rem;
    top: 1.15rem;
    width: 0.62rem;
    height: 0.62rem;
    border-radius: 999px;
    background: var(--accent);
    box-shadow: 0 0 0 4px color-mix(in srgb, var(--accent) 20%, transparent);
  }

  .timeline__item h3 {
    margin-bottom: 0.35rem;
  }

  .timeline__details {
    margin: 0.45rem 0 0;
    padding-left: 1.1rem;
    display: grid;
    gap: 0.3rem;
  }

  .timeline__details li {
    line-height: 1.45;
  }

  .meta {
    color: var(--muted);
    font-size: var(--text-xs);
    font-weight: 600;
    margin-bottom: 0.4rem;
  }

  .spotlight {
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: linear-gradient(180deg, color-mix(in srgb, var(--surface) 90%, transparent), var(--surface));
    box-shadow: var(--shadow);
    padding: 1.2rem;
  }

  .spotlight__top {
    margin-bottom: 0.5rem;
    display: grid;
    gap: 0.3rem;
    justify-items: start;
  }

  .spotlight__top h2 {
    margin: 0;
    text-align: left;
  }

  .spotlight__intro {
    margin: 0 0 1rem;
    font-family: var(--font-heading);
    font-size: 1.18rem;
    line-height: 1.45;
    color: var(--text);
  }

  .spotlight__grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.9rem;
  }

  .spotlight__card {
    padding: 1rem;
    border-radius: calc(var(--radius) - 4px);
    border: 1px solid var(--line);
    background: color-mix(in srgb, var(--bg) 86%, transparent);
  }

  .spotlight__card h3 {
    margin: 0 0 0.45rem;
  }

  .learning-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.8rem;
  }

  .learning-grid li {
    border: 1px solid var(--line);
    background: var(--surface);
    box-shadow: var(--shadow);
    border-radius: var(--radius);
    padding: 0.95rem 1rem;
    font-weight: 500;
    line-height: 1.5;
  }

  .work-link {
    border: 1px solid var(--line);
    background: var(--surface);
    box-shadow: var(--shadow);
    border-radius: var(--radius);
    padding: 1.2rem;
    display: grid;
    gap: 0.85rem;
  }

  .work-link__conclusion {
    margin-top: 0.2rem;
    font-family: var(--font-heading);
    font-size: 1.2rem;
    color: var(--text);
  }

  @media (max-width: 900px) {
    .spotlight__grid,
    .learning-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .timeline__item,
    .spotlight,
    .spotlight__card,
    .learning-grid li,
    .work-link {
      padding: 0.95rem;
    }

    .timeline__item {
      margin-left: 1.15rem;
    }

    .timeline__item::before {
      left: -0.95rem;
    }
  }
</style>
