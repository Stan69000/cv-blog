---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
---

<BaseLayout
  title="Page introuvable | Stan Bouchet"
  description="Cette page n'existe pas."
  noIndex={true}
>
  <SiteHeader />

  <main id="main-content" class="container section page-404">
    <div class="not-found">
      <p class="code" aria-hidden="true">404</p>
      <h1>Page introuvable.</h1>
      <p class="lead muted">
        L'URL ne correspond à aucune page de ce site.
        Elle a peut-être été déplacée, renommée ou simplement n'a jamais existé.
      </p>
      <nav class="links" aria-label="Pages principales">
        <a href="/" class="button button--primary">Accueil</a>
        <a href="/parcours" class="button">Parcours</a>
        <a href="/projets" class="button">Projets</a>
        <a href="/contact" class="button">Contact</a>
      </nav>
    </div>
  </main>

  <SiteFooter />
</BaseLayout>

<style>
  .page-404 {
    min-height: 60vh;
    display: flex;
    align-items: center;
    padding-top: 2rem;
    padding-bottom: 4rem;
  }

  .not-found {
    max-width: 540px;
  }

  .code {
    margin: 0 0 0.5rem;
    font-family: var(--font-heading);
    font-size: clamp(5rem, 14vw, 10rem);
    font-weight: 700;
    line-height: 1;
    letter-spacing: -0.04em;
    background: linear-gradient(135deg, var(--accent), var(--accent-2));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    user-select: none;
  }

  h1 {
    margin: 0 0 1rem;
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    line-height: 1.1;
    letter-spacing: -0.02em;
  }

  .lead {
    margin: 0 0 2rem;
    font-size: 1.1rem;
    line-height: 1.65;
  }

  .links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
  }

  .button--primary {
    background: var(--accent);
    color: var(--accent-contrast);
    border-color: var(--accent);
  }

  .button--primary:hover {
    background: color-mix(in srgb, var(--accent) 85%, var(--text));
    border-color: color-mix(in srgb, var(--accent) 85%, var(--text));
  }

  @media (max-width: 640px) {
    .links .button {
      flex: 1 1 calc(50% - 0.3rem);
      justify-content: center;
    }
  }
</style>
